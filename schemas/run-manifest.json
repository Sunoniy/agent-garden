{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Garden Run Manifest",
  "type": "object",
  "required": ["roundId", "topic", "createdAt", "participants", "stages"],
  "properties": {
    "roundId": {"type": "string"},
    "topic": {"type": "string"},
    "createdAt": {"type": "string"},
    "participants": {"type": "array", "items": {"type": "string"}},
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent", "purpose", "status"],
        "properties": {
          "agent": {"type": "string"},
          "purpose": {"type": "string"},
          "status": {"type": "string", "enum": ["pending", "running", "done", "failed"]},
          "artifact": {"type": "string"}
        }
      }
    },
    "archiveDecision": {"type": ["string", "null"]}
  }
}
