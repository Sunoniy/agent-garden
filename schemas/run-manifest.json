{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Garden Run Manifest",
  "type": "object",
  "required": ["topic", "createdAt", "participants", "statuses", "artifacts"],
  "properties": {
    "topic": {"type": "string"},
    "createdAt": {"type": "string"},
    "participants": {"type": "array", "items": {"type": "string"}},
    "statuses": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["pending", "running", "done", "failed"]
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "archiveDecision": {
      "type": ["string", "null"],
      "enum": ["archive", "hold", "discard", null]
    }
  }
}
